# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
NODE_ENV=development

# Optional database connection for platform integrations.
# Leave empty when running the current local JSON MVP.
DATABASE_URL=
SUDA_DATABASE_URL=
DEPRECATED_SKIP_INIT_DB_CONNECTION=true

# Local storage / runtime paths
STORAGE_PATH=.runtime
MOCK_AI_MODE=true

# Optional OpenAI-compatible provider. Leave API key empty to use Mock AI.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Optional DeepSeek provider used by legacy V1.1 scoring flow.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional Feishu bitable integration for legacy V1.1 flow.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_DRIVE_FOLDER_TOKEN=
FEISHU_WEBHOOK_URL=

# Optional Feishu table ids. Fill only when connecting real Feishu bitable.
FEISHU_TABLE_DIMENSIONS=
FEISHU_TABLE_ASSESSMENT_CONFIGS=
FEISHU_TABLE_BASIC_QUESTIONS=
FEISHU_TABLE_TASK_QUESTIONS=
FEISHU_TABLE_INTEREST_QUESTIONS=
FEISHU_TABLE_EVALUATION_RECORDS=
FEISHU_TABLE_BASIC_ANSWERS=
FEISHU_TABLE_TASK_ANSWERS=
FEISHU_TABLE_INTEREST_ANSWERS=
FEISHU_TABLE_ASSESSMENT_REPORTS=
FEISHU_TABLE_TRAINING_RESOURCES=
FEISHU_TABLE_NOTIFICATIONS=
